{
  "expo": {
    "name": "Converter",
    "slug": "Converter",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "@/assets/image/cupcake.png",
    "scheme": "converter",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "@/assets/image/cupcake.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "@/assets/image/cupcake.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.liendea.Converter"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "@/assets/image/cupcake.png"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "247c3c8e-02e2-41df-b3b2-b112ab583cdc"
      }
    }
  }
}
